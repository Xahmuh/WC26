{
  "expo": {
    "name": "WC26",
    "slug": "wc26-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "wc26",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/favicon.png",

    "splash": {
      "image": "./assets/splashscreen.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F4D7"
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.wc26.app",
      "icon": "./assets/favicon.png"
    },

    "android": {
      "package": "org.wc26.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/favicon.png",
        "backgroundColor": "#0D0F0E"
      }
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },

    "plugins": [
      "expo-router",
      "expo-asset"
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "supabaseUrl": "https://sjqhsmyqlgjbimwkruqd.supabase.co",
