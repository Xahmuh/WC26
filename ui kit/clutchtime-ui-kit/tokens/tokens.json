{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "name": "ClutchTime Design System",
    "version": "1.0.0",
    "description": "Dark Athletic Premium — Sports Calendar Mobile App",
    "platform": "React Native",
    "author": "Reverse-engineered from ClutchTime UI"
  },

  "color": {
    "background": {
      "deep":      { "$value": "#0D0D0D", "$type": "color", "$description": "Deepest bg — status bar area" },
      "primary":   { "$value": "#111111", "$type": "color", "$description": "Main screen background" },
      "secondary": { "$value": "#1A1A1A", "$type": "color", "$description": "Section backgrounds" },
      "surface":   { "$value": "#222222", "$type": "color", "$description": "Card / row surfaces" },
      "elevated":  { "$value": "#2A2A2A", "$type": "color", "$description": "Elevated components, hover" },
      "hover":     { "$value": "#333333", "$type": "color", "$description": "Pressed / hover state" }
    },

    "text": {
      "primary":   { "$value": "#FFFFFF", "$type": "color", "$description": "Headlines, scores, times" },
      "secondary": { "$value": "#CCCCCC", "$type": "color", "$description": "Team names, labels" },
      "muted":     { "$value": "#888888", "$type": "color", "$description": "Records, metadata" },
      "disabled":  { "$value": "#555555", "$type": "color", "$description": "Inactive tabs, placeholders" }
    },

    "accent": {
      "lime":       { "$value": "#C8FF00", "$type": "color", "$description": "Primary accent — active states, CTAs" },
      "lime-dark":  { "$value": "#A0CC00", "$type": "color", "$description": "Pressed lime button" },
      "lime-alpha": { "$value": "rgba(200,255,0,0.12)", "$type": "color", "$description": "Lime tinted bg" },
      "live-red":   { "$value": "#E03030", "$type": "color", "$description": "Live game indicator + border" },
      "live-red-bg":{ "$value": "rgba(224,48,48,0.1)", "$type": "color", "$description": "Live card tinted bg" },
      "live-red-glow": { "$value": "rgba(224,48,48,0.3)", "$type": "color", "$description": "Live card shadow glow" }
    },

    "border": {
      "subtle":  { "$value": "#2A2A2A", "$type": "color", "$description": "Very subtle dividers" },
      "default": { "$value": "#3A3A3A", "$type": "color", "$description": "Default card borders" },
      "strong":  { "$value": "#555555", "$type": "color", "$description": "Emphasized borders" },
      "live":    { "$value": "#E03030", "$type": "color", "$description": "Live card border" },
      "active":  { "$value": "#FFFFFF", "$type": "color", "$description": "Active tab underline" }
    },

    "semantic": {
      "success": { "$value": "#4ADE80", "$type": "color" },
      "warning": { "$value": "#FACC15", "$type": "color" },
      "error":   { "$value": "#F87171", "$type": "color" },
      "info":    { "$value": "#60A5FA", "$type": "color" }
    }
  },

  "typography": {
    "fontFamily": {
      "primary": {
        "$value": "-apple-system, 'SF Pro Display', 'DM Sans', 'Roboto', sans-serif",
        "$type": "fontFamily",
        "$description": "System font stack. iOS uses SF Pro Display automatically."
      }
    },
    "fontSize": {
      "appName": { "$value": 24, "$type": "dimension", "$description": "CLUTCHTIME wordmark" },
      "score":   { "$value": 28, "$type": "dimension", "$description": "Live score digits" },
      "time":    { "$value": 18, "$type": "dimension", "$description": "Upcoming game time" },
      "h1":      { "$value": 20, "$type": "dimension" },
      "h2":      { "$value": 16, "$type": "dimension" },
      "body":    { "$value": 14, "$type": "dimension" },
      "teamAbbr":{ "$value": 13, "$type": "dimension", "$description": "Team abbreviations (GSW, BOS)" },
      "tab":     { "$value": 13, "$type": "dimension", "$description": "Sport filter tabs" },
      "label":   { "$value": 12, "$type": "dimension" },
      "caption": { "$value": 10, "$type": "dimension", "$description": "League name, metadata" },
      "micro":   { "$value": 9,  "$type": "dimension", "$description": "Wins-Losses record" }
    },
    "fontWeight": {
      "regular":  { "$value": "400", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" },
      "bold":     { "$value": "700", "$type": "fontWeight" },
      "black":    { "$value": "800", "$type": "fontWeight", "$description": "Scores, times, app name" }
    },
    "letterSpacing": {
      "tight":  { "$value": -0.5, "$type": "dimension", "$description": "App name" },
      "normal": { "$value": 0,    "$type": "dimension" },
      "score":  { "$value": 0.05, "$type": "dimension", "$description": "Score digits" },
      "wide":   { "$value": 0.08, "$type": "dimension", "$description": "Uppercase labels" }
    },
    "lineHeight": {
      "tight":  { "$value": 1.1, "$type": "number" },
      "normal": { "$value": 1.4, "$type": "number" },
      "relaxed":{ "$value": 1.6, "$type": "number" }
    }
  },

  "spacing": {
    "$description": "Base 4px grid. Use scale[n] for consistency.",
    "base": { "$value": 4, "$type": "dimension" },
    "1":  { "$value": 4,  "$type": "dimension" },
    "2":  { "$value": 8,  "$type": "dimension", "$description": "Icon gaps, tight inline" },
    "3":  { "$value": 12, "$type": "dimension", "$description": "Component internal padding" },
    "4":  { "$value": 16, "$type": "dimension", "$description": "Card padding" },
    "5":  { "$value": 20, "$type": "dimension", "$description": "Section gap" },
    "6":  { "$value": 24, "$type": "dimension", "$description": "Horizontal screen gutters" },
    "8":  { "$value": 32, "$type": "dimension", "$description": "Section spacing" },
    "12": { "$value": 48, "$type": "dimension", "$description": "Large layout gaps" }
  },

  "borderRadius": {
    "xs":   { "$value": 4,    "$type": "dimension", "$description": "Quarter badges, micro pills" },
    "sm":   { "$value": 8,    "$type": "dimension", "$description": "Input fields" },
    "md":   { "$value": 12,   "$type": "dimension", "$description": "Game row cards" },
    "lg":   { "$value": 14,   "$type": "dimension", "$description": "Live card, league pills section" },
    "xl":   { "$value": 16,   "$type": "dimension", "$description": "Large cards" },
    "2xl":  { "$value": 24,   "$type": "dimension" },
    "pill": { "$value": 9999, "$type": "dimension", "$description": "Sport filter tabs, nav bar" },
    "full": { "$value": "50%","$type": "dimension", "$description": "League/channel avatar circles" }
  },

  "borderWidth": {
    "default": { "$value": 1,   "$type": "dimension", "$description": "Regular cards and surfaces" },
    "live":    { "$value": 1.5, "$type": "dimension", "$description": "Live score card" },
    "active":  { "$value": 2,   "$type": "dimension", "$description": "Active tab underline" }
  },

  "shadow": {
    "card": {
      "$value": {
        "color": "rgba(0,0,0,0.6)",
        "offsetX": 0,
        "offsetY": 2,
        "blur": 8,
        "spread": 0
      },
      "$type": "shadow",
      "$description": "Default card elevation"
    },
    "nav": {
      "$value": {
        "color": "rgba(0,0,0,0.8)",
        "offsetX": 0,
        "offsetY": 4,
        "blur": 24,
        "spread": 0
      },
      "$type": "shadow",
      "$description": "Floating bottom navigation pill"
    },
    "liveGlow": {
      "$value": {
        "color": "rgba(224,48,48,0.3)",
        "offsetX": 0,
        "offsetY": 0,
        "blur": 16,
        "spread": 0
      },
      "$type": "shadow",
      "$description": "Live card red ambient glow (iOS shadow)"
    }
  },

  "animation": {
    "duration": {
      "fast":   { "$value": 150, "$type": "duration" },
      "normal": { "$value": 250, "$type": "duration" },
      "slow":   { "$value": 400, "$type": "duration" }
    },
    "easing": {
      "default": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" },
      "spring":  { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier" }
    }
  },

  "icon": {
    "size": {
      "sm": { "$value": 16, "$type": "dimension" },
      "md": { "$value": 20, "$type": "dimension", "$description": "Nav bar icons" },
      "lg": { "$value": 24, "$type": "dimension" },
      "xl": { "$value": 28, "$type": "dimension" }
    },
    "style": "outline",
    "library": "react-native-vector-icons/Ionicons"
  },

  "component": {
    "leaguePill": {
      "size":         { "$value": 48, "$type": "dimension" },
      "borderRadius": { "$value": 9999, "$type": "dimension" },
      "borderWidth":  { "$value": 1, "$type": "dimension" },
      "borderColor":  { "$value": "#333333" }
    },
    "sportTab": {
      "paddingHorizontal": { "$value": 16, "$type": "dimension" },
      "paddingVertical":   { "$value": 6,  "$type": "dimension" },
      "borderRadius":      { "$value": 9999, "$type": "dimension" },
      "active": {
        "bg":   { "$value": "#C8FF00" },
        "text": { "$value": "#111111" }
      },
      "inactive": {
        "bg":     { "$value": "#252525" },
        "text":   { "$value": "#777777" },
        "border": { "$value": "#333333" }
      }
    },
    "liveCard": {
      "bg":           { "$value": "#1E1E1E" },
      "borderWidth":  { "$value": 1.5, "$type": "dimension" },
      "borderColor":  { "$value": "#E03030" },
      "borderRadius": { "$value": 14, "$type": "dimension" },
      "padding":      { "$value": 14, "$type": "dimension" }
    },
    "gameRow": {
      "bg":           { "$value": "#222222" },
      "borderRadius": { "$value": 12, "$type": "dimension" },
      "paddingV":     { "$value": 12, "$type": "dimension" },
      "paddingH":     { "$value": 16, "$type": "dimension" }
    },
    "bottomNav": {
      "bg":               { "$value": "#1C1C1C" },
      "borderRadius":     { "$value": 32, "$type": "dimension" },
      "borderWidth":      { "$value": 1,  "$type": "dimension" },
      "borderColor":      { "$value": "#2A2A2A" },
      "paddingHorizontal":{ "$value": 24, "$type": "dimension" },
      "paddingVertical":  { "$value": 10, "$type": "dimension" },
      "gap":              { "$value": 28, "$type": "dimension" },
      "iconSize":         { "$value": 20, "$type": "dimension" },
      "iconActive":       { "$value": "#FFFFFF" },
      "iconInactive":     { "$value": "#555555" },
      "dotColor":         { "$value": "#C8FF00" },
      "dotSize":          { "$value": 4,  "$type": "dimension" },
      "bottomOffset":     { "$value": 16, "$type": "dimension" }
    }
  }
}
